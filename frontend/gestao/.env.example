VERSION=0.0.0
CADASTROS_URL=http://localhost:9000/api/v1
DATABASE_URL="postgresql://username:password@localhost:5432/db_starter?schema=frontend"
PRISMA_LOG_QUERIES=false
BETTER_AUTH_URL=http://localhost:5137
BETTER_AUTH_SECRET=
AUTHZ_COOKIE_NAME=starter.authz
AUTHZ_COOKIE_FALLBACK_MAX_AGE_SECONDS=300
AUTHZ_COOKIE_SAFETY_WINDOW_SECONDS=30
KEYCLOAK_ISSUER=https://keycloak.dummy.com/realms/starter
KEYCLOAK_CLIENT_ID=webapp
KEYCLOAK_CLIENT_SECRET=
