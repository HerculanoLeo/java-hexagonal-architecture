{
	"name": "starter",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"generate-routes": "tsr generate",
		"db:generate": "dotenv -e .env.local -- prisma generate",
		"db:migrate": "dotenv -e .env.local -- prisma migrate dev",
		"db:deploy": "dotenv -e .env.local -- prisma migrate deploy",
		"db:seed": "dotenv -e .env.local -- prisma db seed",
		"build": "DATABASE_URL=\"${DATABASE_URL:-postgresql://null:null@localhost:5432/null?schema=frontend}\" prisma generate && vite build",
		"start:prod": "prisma migrate deploy && node dist/server/index.mjs",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint",
		"format": "prettier --write . && eslint --fix",
		"check": "prettier --check ."
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@t3-oss/env-core": "^0.13.10",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-form": "latest",
		"@tanstack/react-query": "latest",
		"@tanstack/react-query-devtools": "latest",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/router-plugin": "^1.132.0",
		"better-auth": "^1.6.19",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.4.0",
		"dotenv": "^17.4.2",
		"lucide-react": "^0.577.0",
		"next-themes": "^0.4.6",
		"nitro": "3.0.260610-beta",
		"pg": "^8.22.0",
		"radix-ui": "^1.6.0",
		"react": "^19.2.0",
		"react-day-picker": "^10.0.1",
		"react-dom": "^19.2.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.0.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.3.6",
		"vaul": "^1.1.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@rolldown/plugin-babel": "^0.2.3",
		"@tailwindcss/typography": "^0.5.16",
		"@tanstack/devtools-vite": "latest",
		"@tanstack/eslint-config": "latest",
		"@tanstack/router-cli": "^1.132.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.10",
		"babel-plugin-react-compiler": "^1.0.0",
		"dotenv-cli": "^11.0.0",
		"eslint": "^9.20.0",
		"eslint-plugin-boundaries": "^7.0.2",
		"jsdom": "^28.1.0",
		"prettier": "^3.8.1",
		"prisma": "^7.8.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.0",
		"vitest": "^4.1.10"
	}
}
